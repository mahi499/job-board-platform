// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(JOB_SEEKER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  applications   JobApplication[]
  jobsPosted     Job[]              @relation("PostedBy")
  profile        UserProfile?
  notifications  Notification[]

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  bio           String?  @db.Text
  location      String?
  phone         String?
  skills        String[]  @default([])
  experience    String?
  education     String?
  resumeUrl     String?
  portfolioUrl  String?
  linkedInUrl   String?
  githubUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Job {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  company         String
  location        String
  jobType         JobType  @default(FULL_TIME)
  salaryMin       Float?
  salaryMax       Float?
  currency        String   @default("USD")
  category        String
  tags            String[]  @default([])
  requiredSkills  String[]  @default([])
  postedBy        String
  publishedAt     DateTime @default(now())
  expiresAt       DateTime?
  views           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author         User @relation("PostedBy", fields: [postedBy], references: [id], onDelete: Cascade)
  applications   JobApplication[]

  @@index([postedBy])
  @@index([isActive])
  @@index([category])
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  userId      String
  status      ApplicationStatus @default(PENDING)
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  coverLetter String?  @db.Text
  rating      Int?
  feedback    String?  @db.Text

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  ACCEPTED
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_STATUS_CHANGED
  NEW_JOB_POSTED
  JOB_EXPIRING_SOON
  MESSAGE
}
